# —— Supabase（数据库）——
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 仅服务端使用，切勿暴露到客户端

# —— 赛程 / 比分数据源（football-data.org）——
FOOTBALL_DATA_TOKEN=your-football-data-token

# —— 大模型（OpenAI 兼容接口，用于 AI 推演与快讯摘要）——
DEEPSEEK_API_KEY=your-llm-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# —— 定时任务口令（保护 /api/sync、/api/news/sync 等 cron 入口）——
CRON_SECRET=your-cron-secret

# —— EV 分析参考盘（The Odds API）——
# 免费版 500 次/月；2h 缓存，实际约 <360 次/月。申请：https://the-odds-api.com
# 不填则引擎自动退回体彩盘自评（无需参考盘也能运行）。
ODDS_API_KEY=your-the-odds-api-key
# 赛事标识符，世界杯正赛用 soccer_worldcup，可通过 /v4/sports/ 查询可用 key
ODDS_API_SPORT_KEY=soccer_worldcup
